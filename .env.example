# =============================================================================
# TeacherOS - Environment Configuration
# =============================================================================
# Copy this file to .env.development, .env.staging, or .env.production
# and update the values accordingly.
#
# Usage:
#   cp .env.example .env.development  # for local development
#   cp .env.example .env.staging       # for staging
#   cp .env.example .env.production    # for production
# =============================================================================

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_NAME=TeacherOS
VERSION=0.1.0

# ---------------------------------------------------------------------------
# Database - PostgreSQL
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://teacheros:teacheros_password@teacheros-postgres:5432/teacheros
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_PRE_PING=true

POSTGRES_DB=teacheros
POSTGRES_USER=teacheros
POSTGRES_PASSWORD=teacheros_password
POSTGRES_HOST=teacheros-postgres
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://teacheros-redis:6379/0
REDIS_TOKEN_BLACKLIST_DB=1
REDIS_RATE_LIMIT_DB=2
REDIS_SESSION_DB=3
REDIS_OTP_DB=4

REDIS_HOST=teacheros-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# JWT / Authentication
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=teacher-os
JWT_AUDIENCE=
JWT_LEEWAY_SECONDS=30
JWT_SECRET=change-this-to-a-512-bit-random-secret-in-production

# ---------------------------------------------------------------------------
# Argon2 Password Hashing
# ---------------------------------------------------------------------------
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=102400
ARGON2_PARALLELISM=8
ARGON2_HASH_LEN=32
ARGON2_SALT_LEN=16

# ---------------------------------------------------------------------------
# Password Policy
# ---------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HISTORY_COUNT=5
PASSWORD_MAX_AGE_DAYS=90

# ---------------------------------------------------------------------------
# Multi-Factor Authentication
# ---------------------------------------------------------------------------
MFA_EMAIL_OTP_EXPIRE_SECONDS=300
MFA_TOTP_ISSUER=TeacherOS
MFA_TOTP_VALIDITY_WINDOW=1
MFA_ENABLED=false

# ---------------------------------------------------------------------------
# Encryption
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=change-this-to-a-256-bit-base64-encoded-key
ENCRYPTION_ALGORITHM=AES-256-GCM

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Tenant-Id,X-Request-Id,X-CSRF-Token
CORS_EXPOSE_HEADERS=X-Request-Id,X-RateLimit-Limit,X-RateLimit-Remaining,X-RateLimit-Reset

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_PUBLIC_REQUESTS=10
RATE_LIMIT_PUBLIC_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AI_REQUESTS=20
RATE_LIMIT_AI_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300

# ---------------------------------------------------------------------------
# File Upload Security
# ---------------------------------------------------------------------------
FILE_UPLOAD_MAX_SIZE_MB=10
FILE_UPLOAD_ALLOWED_EXTENSIONS=pdf,docx,xlsx,png,jpeg,jpg
FILE_UPLOAD_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,image/png,image/jpeg
FILE_UPLOAD_SCAN_ENABLED=false

# ---------------------------------------------------------------------------
# MinIO (S3-compatible Storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=teacheros_admin
MINIO_ROOT_PASSWORD=teacheros_minio_password
MINIO_ENDPOINT=http://teacheros-storage:9000
MINIO_ACCESS_KEY=teacheros_access
MINIO_SECRET_KEY=teacheros_secret_key
MINIO_REGION=ap-southeast-1
MINIO_BUCKET_UPLOADS=teacheros-uploads
MINIO_BUCKET_REPORTS=teacheros-reports
MINIO_BUCKET_AI_OUTPUTS=teacheros-ai-outputs
MINIO_BUCKET_PDFS=teacheros-pdfs

# ---------------------------------------------------------------------------
# Celery / Task Queue
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://teacheros-redis:6379/0
CELERY_RESULT_BACKEND=redis://teacheros-redis:6379/0
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3000

# ---------------------------------------------------------------------------
# AI Provider Keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-haiku-20240307

AI_MAX_INPUT_LENGTH=100000
AI_OUTPUT_FILTER_ENABLED=true
AI_PROMPT_INJECTION_DETECTION_ENABLED=true
AI_CROSS_TENANT_CONTEXT_CHECK=true
AI_MAX_TOOL_CALLS_PER_RUN=50

# ---------------------------------------------------------------------------
# Local AI (Ollama) - Optional
# ---------------------------------------------------------------------------
OLLAMA_ENABLED=false
OLLAMA_HOST=http://teacheros-ollama:11434
OLLAMA_MODEL=llama3.1

# ---------------------------------------------------------------------------
# Email Configuration
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_FROM_EMAIL=noreply@teacheros.ph
SMTP_FROM_NAME=TeacherOS

# ---------------------------------------------------------------------------
# Observability & Monitoring
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://teacheros-otel-collector:4317
OTEL_SERVICE_NAME=teacheros-api
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

PROMETHEUS_METRICS_PORT=8000
PROMETHEUS_PUSHGATEWAY=http://teacheros-prometheus-pushgateway:9091

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=teacheros_grafana_admin

# ---------------------------------------------------------------------------
# pgAdmin
# ---------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@teacheros.ph
PGADMIN_DEFAULT_PASSWORD=teacheros_pgadmin_password

# ---------------------------------------------------------------------------
# Multi-Tenancy
# ---------------------------------------------------------------------------
TENANT_HEADER_NAME=X-Tenant-Id
TENANT_DEFAULT=default
TENANT_ORGANIZATION_HEADER=X-Organization-Id
TENANT_SCHOOL_HEADER=X-School-Id

# ---------------------------------------------------------------------------
# Audit Logging
# ---------------------------------------------------------------------------
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_APPEND_ONLY=true
AUDIT_LOG_TABLE=audit_logs

# ---------------------------------------------------------------------------
# Data Retention / Compliance
# ---------------------------------------------------------------------------
DATA_RETENTION_STUDENT_RECORDS_YEARS=5
DATA_RETENTION_AUDIT_LOGS_YEARS=3
DATA_RETENTION_SESSION_LOGS_DAYS=90
DATA_RETENTION_AI_INTERACTION_LOGS_DAYS=180

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------
DOMAIN=teacheros.ph
API_DOMAIN=api.teacheros.ph
FRONTEND_DOMAIN=app.teacheros.ph
SSL_EMAIL=admin@teacheros.ph

# ---------------------------------------------------------------------------
# Docker Compose Specific
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=teacheros
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ---------------------------------------------------------------------------
# Registry (for CI/CD)
# ---------------------------------------------------------------------------
REGISTRY=docker.io
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Backup Configuration
# ---------------------------------------------------------------------------
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=teacheros-backups
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_AWS_REGION=ap-southeast-1

# ---------------------------------------------------------------------------
# Database URLs for different environments (computed)
# ---------------------------------------------------------------------------
DATABASE_URL__DEV=postgresql://teacheros:teacheros_password@teacheros-postgres:5432/teacheros
DATABASE_URL__STAGING=postgresql://teacheros:${POSTGRES_PASSWORD}@teacheros-postgres:5432/teacheros
DATABASE_URL__PROD=postgresql://teacheros:${POSTGRES_PASSWORD}@teacheros-postgres:5432/teacheros